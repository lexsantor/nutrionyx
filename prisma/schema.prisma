// Nutrionyx slice 1 - Assessment aggregate and identity spine.
// Domain source: docs/09_Domain_Model.md. Every model is org-scoped.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String    @id @default(cuid())
  // Better Auth organization id (Neon Auth); see deviations/0001.
  authOrgId String    @unique
  name      String
  // Consulta profile (docs/build/slice-4-plan.md). All optional; fiscal
  // fields feed Billing invoices later. Editable by the owning specialist.
  legalName   String?
  taxId       String?
  addressLine String?
  locality    String?
  postalCode  String?
  country     String?  @default("ES")
  hours       String?
  logoUrl     String?
  slug        String?  @unique
  createdAt DateTime  @default(now())
  patients  Patient[]

  @@map("organizations")
}

enum PatientStatus {
  INVITED
  ACTIVE
}

model Patient {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  // Better Auth user id (Neon Auth); set when the invited patient activates.
  authUserId     String?       @unique
  email          String
  fullName       String?
  status         PatientStatus @default(INVITED)
  createdAt      DateTime      @default(now())
  assessments    Assessment[]
  measurements   Measurement[]

  // Invariant (docs/09): every patient belongs to exactly one organization.
  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("patients")
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
}

enum ActivityLevel {
  LOW
  MEDIUM
  HIGH
}

enum Sex {
  FEMALE
  MALE
}

model Assessment {
  id             String           @id @default(cuid())
  organizationId String
  patientId      String
  patient        Patient          @relation(fields: [patientId], references: [id])
  status         AssessmentStatus @default(IN_PROGRESS)
  version        Int              @default(1)
  predecessorId  String?          @unique
  predecessor    Assessment?      @relation("AssessmentVersions", fields: [predecessorId], references: [id])
  successor      Assessment?      @relation("AssessmentVersions")

  // Core clinical intake (editable while IN_PROGRESS, frozen at COMPLETED;
  // required-at-completion is enforced in the domain layer, not the schema)
  sex               Sex?
  birthDate         DateTime?
  heightCm          Decimal?  @db.Decimal(5, 1)
  weightKg          Decimal?  @db.Decimal(5, 1)
  targetWeightKg    Decimal?  @db.Decimal(5, 1)
  activityLevel     ActivityLevel?
  goals             String[]
  conditions        String?
  allergies         String?
  currentMedication String?

  // Computed at completion (docs/09: BMI, target delta ratio)
  bmi              Decimal? @db.Decimal(4, 1)
  targetDeltaRatio Decimal? @db.Decimal(5, 4)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@unique([patientId, version])
  @@index([organizationId])
  @@map("assessments")
}

// Append-only domain events (docs/09: AssessmentStarted, AssessmentCompleted)
model DomainEvent {
  id             String   @id @default(cuid())
  organizationId String
  aggregate      String
  aggregateId    String
  type           String
  payload        Json
  createdAt      DateTime @default(now())

  @@index([organizationId, aggregate, aggregateId])
  @@map("domain_events")
}

// Append-only patient metrics over time (docs/09 Measurement child of
// Patient, docs/build/slice-2-plan.md). Weight only for this slice; never
// updated or deleted - a correction is a new row.
enum MeasurementKind {
  WEIGHT
}

model Measurement {
  id             String          @id @default(cuid())
  organizationId String
  patientId      String
  patient        Patient         @relation(fields: [patientId], references: [id])
  kind           MeasurementKind @default(WEIGHT)
  value          Decimal         @db.Decimal(5, 1)
  recordedAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([organizationId, patientId, recordedAt])
  @@map("measurements")
}

// Single-use codes issued by the Nutrionyx owner to gate specialist
// (nutritionist) onboarding: creating a consulta requires redeeming one
// (docs/adr/0003). Redemption is atomic via an updateMany guard.
model SpecialistAccessCode {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  usedAt    DateTime?
  usedBy    String?
  createdBy String?
  createdAt DateTime  @default(now())

  @@map("specialist_access_codes")
}

// Platform-owner allowlist (docs/build/slice-3-plan.md, adr/0004). A user in
// this table is the platform Super Admin - business/platform operations only,
// never patient clinical data (operator-blindness).
model PlatformAdmin {
  id         String   @id @default(cuid())
  authUserId String   @unique
  note       String?
  createdAt  DateTime @default(now())

  @@map("platform_admins")
}
